{
  "name": "a-blog-allinone",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Blog All-in-One 1st MVP workspace",
  "scripts": {
    "install:all": "npm install --prefix frontend && npm install --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "build": "npm run build --prefix frontend",
    "diagnose:preview": "node scripts/diagnose-blog-preview.mjs",
    "diagnose:preview:auto": "node scripts/diagnose-blog-preview.mjs --auto",
    "diagnose:quality:auto": "node scripts/diagnose-blog-quality.mjs --auto",
    "test:local": "node tests/local-validation.test.mjs",
    "start": "npm run start --prefix backend"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "devDependencies": {
    "@playwright/test": "^1.61.0"
  }
}
